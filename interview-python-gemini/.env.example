# ── Google Gemini API (100% FREE) ─────────────────────
# Step 1: Go to https://aistudio.google.com/app/apikey
# Step 2: Sign in with your Google account
# Step 3: Click "Create API Key"
# Step 4: Copy the key and paste it below
GEMINI_API_KEY="AIzaSyAGymKuhRMCzZGB8GXVqsruzi1IIXYFGj0"

# ── Gemini Model ───────────────────────────────────────
# gemini-1.5-flash  → faster, free tier (recommended)
# gemini-1.5-pro    → smarter, still free but lower rate limit
GEMINI_MODEL="gemini-1.5-flash"

# ── Whisper Mode (Speech to Text) ─────────────────────
# "local" → runs on your PC for free (recommended)
# Needs ~500MB RAM for "base" model
WHISPER_MODE="local"
WHISPER_MODEL_SIZE="base"   # tiny | base | small | medium | large

# ── Server ─────────────────────────────────────────────
PORT=8000
