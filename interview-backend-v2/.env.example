# ── DATABASE ──────────────────────────────────────────────────
# Format: postgresql://USER:PASSWORD@HOST:PORT/DATABASE_NAME
DATABASE_URL="Enter-your-api-key"

# ── AUTH ───────────────────────────────────────────────────────
# Any long random string — used to sign JWT tokens
# Generate one at: https://generate-secret.vercel.app/64
JWT_SECRET="your-super-secret-jwt-key-change-this"
JWT_EXPIRES_IN="7d"

# ── SERVER ─────────────────────────────────────────────────────
PORT=5000
CLIENT_URL="http://localhost:5173"

# ── REDIS ──────────────────────────────────────────────────────
REDIS_HOST="127.0.0.1"
REDIS_PORT=6379

# ── LOCAL FILE STORAGE ─────────────────────────────────────────
# All uploaded files are saved to these folders on your computer.
# These folders are created automatically — you don't need to
# create them manually.
RESUME_UPLOAD_DIR="uploads/resumes"
AUDIO_UPLOAD_DIR="uploads/audio"
MAX_RESUME_SIZE_MB=5
MAX_AUDIO_SIZE_MB=50

# ── PYTHON AI MICROSERVICES ────────────────────────────────────
# URL of your Python service (you will build this next)
PYTHON_SERVICE_URL="http://localhost:8000"
